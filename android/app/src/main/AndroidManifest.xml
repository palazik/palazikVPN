<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Required for requestNetwork() in NetworkCallback (v2rayNG uses this to set
         setUnderlyingNetworks so xray outbound sockets bypass the TUN interface) -->
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />

    <!-- Split tunneling needs to enumerate installed apps (including non-launcher ones)
         so the user can pick which apps bypass the VPN. On Android 11+ this requires
         broad package visibility. -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Fallback visibility for launcher apps if QUERY_ALL_PACKAGES is unavailable -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:name=".palazikVPNApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.palazikVPN"
        tools:targetApi="34">

        <meta-data
            android:name="com.palazik.vpn.VERSION_NAME"
            android:value="@string/app_version" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Deep-link handler: palazikvpn://import?config=vmess://... plus native links -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="palazikvpn" />
                <data android:scheme="vmess" />
                <data android:scheme="vless" />
                <data android:scheme="ss" />
                <data android:scheme="trojan" />
                <data android:scheme="hysteria2" />
                <data android:scheme="wireguard" />
                <data android:scheme="socks5" />
                <data android:scheme="tuic" />
                <data android:scheme="anytls" />
                <data android:scheme="xhttp" />
                <data android:scheme="httpproxy" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.palazikVpnService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
            <meta-data
                android:name="android.net.VpnService.SUPPORTS_ALWAYS_ON"
                android:value="true" />
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="vpn" />
        </service>

        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Home-screen widget to toggle the VPN and show current state -->
        <receiver
            android:name=".widget.VpnWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.palazik.vpn.WIDGET_TOGGLE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_vpn_info" />
        </receiver>

        <!-- Quick Settings tile to toggle the VPN from the shade -->
        <service
            android:name=".service.VpnTileService"
            android:exported="true"
            android:icon="@drawable/ic_vpn_key"
            android:label="palazikVPN"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

    </application>
</manifest>
