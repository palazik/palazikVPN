<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- Exclude everything from cloud backup AND device-to-device transfer so VPN
         credentials (UUIDs, passwords, WireGuard private keys) in SharedPreferences are
         never copied off-device. Use the in-app Backup/restore to migrate intentionally. -->
    <cloud-backup><exclude domain="root" path="." /></cloud-backup>
    <device-transfer><exclude domain="root" path="." /></device-transfer>
</data-extraction-rules>
